{
  "packages": ["rustup@latest", "protobuf@latest", "openssl@latest", "pkg-config@latest", "git@latest"],
  "shell": {
    "init_hook": ["rustup default stable", "echo '🚀 Devbox: Convex Backend & Dashboard siap digunakan!'"],
    "scripts": {
      "setup": "git clone https://github.com/get-convex/convex-backend.git .convex-local",
      "start": "cd .convex-local && cargo run --bin convex-local-backend",
      "start:release": "cd .convex-local && cargo run --release --bin convex-local-backend",
      "build:release": "cd .convex-local && cargo build --release --bin convex-local-backend"
    }
  }
}
