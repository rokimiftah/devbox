{
  "packages": ["rustup@latest", "protobuf@latest", "openssl@latest", "pkg-config@latest", "git@latest", "gnumake@latest"],
  "env": {
    "BINDGEN_EXTRA_CLANG_ARGS": "-I/usr/include"
  },
  "shell": {
    "init_hook": [
      "rustup default stable",
      "export LIBCLANG_PATH=\"$(nix run --impure nixpkgs#llvmPackages.libclang --print-out-paths)/lib\"",
      "export LD_LIBRARY_PATH=\"$(nix run --impure nixpkgs#llvmPackages.libcxx --print-out-paths)/lib:$LD_LIBRARY_PATH\"",
      "echo '🚀 Devbox: Lingkungan Kompilasi Convex (dengan C++ Bindgen) siap!'"
    ],
    "scripts": {
      "setup": "git clone https://github.com/get-convex/convex-backend.git .convex-local",
      "start": "cd .convex-local && cargo run --bin convex-local-backend",
      "start:release": "cd .convex-local && cargo run --release --bin convex-local-backend",
      "build:release": "cd .convex-local && cargo build --release --jobs 2 --bin convex-local-backend"
    }
  }
}
