{
  "packages": [
    "rustup@latest",
    "protobuf@latest",
    "openssl@latest",
    "pkg-config@latest",
    "git@latest",
    "gnumake@latest",
    "clang",
    "libclang",
    "nodejs@22",
    "python3",
    "just"
  ],
  "shell": {
    "init_hook": [
      "rustup default stable",
      "export LIBCLANG_PATH=$(find /nix/store -name \"libclang.so\" 2>/dev/null | head -n 1 | xargs dirname)",
      "export CFLAGS=\"-w\"",
      "export CXXFLAGS=\"-w -include stdint.h\"",
      "echo '🚀 Devbox: Siap untuk kompilasi!'"
    ],
    "scripts": {
      "setup": "[ -d .convex-local ] || git clone https://github.com/get-convex/convex-backend.git .convex-local",
      "start": "cd .convex-local && cargo run --bin convex-local-backend",
      "start:release": "cd .convex-local && cargo run --release --bin convex-local-backend",
      "build:release": "cd .convex-local/scripts && npm ci && cd .. && cargo build --release --jobs 2 --bin convex-local-backend"
    }
  }
}
